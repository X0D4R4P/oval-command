generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  unlockedAchievements Json @default("[]")
  accounts      Account[]
  sessions      Session[]
  games         Game[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Game {
  id              String     @id @default(cuid())
  userId          String
  presidentName   String
  party           Party
  difficulty      String     @default("normal")
  currentMonth    Int        @default(1)
  status          GameStatus @default(ACTIVE)
  stats           Json
  flags           Json       @default("{}")
  activeConflicts Json       @default("[]")
  activeScandals  Int        @default(0)
  pendingConsequences Json   @default("[]")
  chainCooldowns  Json       @default("{}")
  npcRelationships Json      @default("{}")
  usedNpcAbilities Json      @default("[]")
  passedLaws      Json       @default("[]")
  usedEvents      Json       @default("[]")
  approvalHistory Json       @default("[]")
  cabinetSelections Json     @default("{}")
  npcTraits       Json       @default("{}")
  npcObservations Json       @default("{}")
  priorities      Json       @default("[]")
  legacyScore     Int?
  currentEventId  String?
  createdAt       DateTime   @default(now()) @db.Timestamp(3)
  // Capped at millisecond precision because turn/law routes use this column
  // for optimistic locking (WHERE updatedAt: <value read via Prisma>) — Postgres's
  // default timestamp precision is microseconds, but JS Date (and therefore
  // Prisma's read-back value) only holds milliseconds, so an update's WHERE
  // clause would never match its own previous write and every turn past the
  // first would fail with a false "already processed" conflict.
  updatedAt       DateTime   @updatedAt @db.Timestamp(3)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs            GameLog[]

  @@index([userId, updatedAt])
  @@index([status, legacyScore])
}

model GameLog {
  id          String     @id @default(cuid())
  gameId      String
  month       Int
  actionType  ActionType
  eventId     String?
  choiceIndex Int?
  lawId       String?
  statDeltas  Json
  narrative   String?
  createdAt   DateTime   @default(now())
  game        Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId, month])
}

enum Party {
  DEMOCRAT
  REPUBLICAN
  INDEPENDENT
}

enum GameStatus {
  ACTIVE
  COMPLETE
  GAMEOVER
}

enum ActionType {
  CRISIS
  LAW_PROPOSED
  LAW_PASSED
  LAW_FAILED
  BUDGET
  EXECUTIVE_ORDER
  PRESS_CONFERENCE
  DIPLOMATIC_VISIT
  TURN_END
  PERSONNEL
}
